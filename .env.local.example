# Social Automation - Variabili ambiente
# Copia in .env.local e sostituisci con i valori reali.

# Database Supabase (Postgres) via pooler Supavisor.
# Runtime: transaction mode :6543. Migrazioni: session mode :5432 (DIRECT_DATABASE_URL).
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DIRECT_DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Auth NextAuth
AUTH_SECRET=change-me-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI - almeno una chiave
# Anthropic (per modelli Claude: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5)
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (per modelli free/esterni - opzionale se ANTHROPIC_API_KEY è configurata)
# OPENROUTER_API_KEY=sk-or-v1-...

# Demo mode override esplicito (true = forza demo)
# Lascia commentato in produzione.
# NEXT_PUBLIC_DEMO_MODE=true

# Blotato
BLOTATO_API_KEY=
BLOTATO_API_URL=https://backend.blotato.com
BLOTATO_BACKEND_URL=https://backend.blotato.com
BLOTATO_WEBHOOK_SECRET=generate-with-openssl-rand-base64-32

# Stripe pagamenti
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=generate-with-openssl-rand-base64-32

# Storage media S3-compatible (Supabase Storage). Obbligatorio su Vercel.
STORAGE_ENDPOINT=https://<ref>.supabase.co/storage/v1/s3
STORAGE_REGION=<region>
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=media
# STORAGE_PUBLIC_URL=https://<ref>.supabase.co/storage/v1/object/public/media

# Solo demo controllata. Non attivare in produzione venduta.
# SHOW_LOGIN_HINT=true
