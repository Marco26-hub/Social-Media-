# Social Automation - Variabili ambiente
# Copia in .env.local e sostituisci con i valori reali.

# Database Neon/Postgres
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Auth NextAuth
AUTH_SECRET=change-me-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI - almeno una chiave
# Anthropic (per modelli Claude: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5)
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (per modelli free/esterni - opzionale se ANTHROPIC_API_KEY è configurata)
# OPENROUTER_API_KEY=sk-or-v1-...

# Demo mode override esplicito (true = forza demo)
# Lascia commentato in produzione.
# NEXT_PUBLIC_DEMO_MODE=true

# Blotato
BLOTATO_API_KEY=
BLOTATO_API_URL=https://api.blotato.com
BLOTATO_WEBHOOK_SECRET=generate-with-openssl-rand-base64-32

# Stripe pagamenti
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=generate-with-openssl-rand-base64-32

# Solo demo controllata. Non attivare in produzione venduta.
# SHOW_LOGIN_HINT=true
