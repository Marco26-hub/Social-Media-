# Social Automation - Variabili ambiente
# Copia in .env.local e sostituisci con i valori reali.

# Database Neon/Postgres
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Auth NextAuth
AUTH_SECRET=change-me-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000

# AI - almeno una chiave
# Anthropic (per modelli Claude: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5)
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (per modelli free/esterni - opzionale se ANTHROPIC_API_KEY è configurata)
# OPENROUTER_API_KEY=sk-or-v1-...

# Demo mode override esplicito (true = forza demo)
# Lascia commentato in produzione.
# NEXT_PUBLIC_DEMO_MODE=true
