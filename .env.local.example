# Social Automation - Variabili ambiente
# Copia in .env.local e sostituisci con i valori reali del tuo progetto Supabase.

# Supabase (produzione)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# n8n webhook base (workflow generazione/audit/piano)
NEXT_PUBLIC_N8N_WEBHOOK_BASE=https://your-n8n-host/webhook

# Demo mode override esplicito (true = forza demo anche con URL Supabase reale)
# Lascia commentato in produzione. Il sistema entra in demo automaticamente se
# l'URL Supabase contiene placeholder/test-project/xxxx/your-project/localhost.
# NEXT_PUBLIC_DEMO_MODE=true
