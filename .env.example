# Neon Database
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI - almeno una chiave
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Blotato (quando pronto)
BLOTATO_API_KEY=
BLOTATO_API_URL=https://backend.blotato.com
BLOTATO_BACKEND_URL=https://backend.blotato.com
BLOTATO_WEBHOOK_SECRET=generate-with-openssl-rand-base64-32

# Stripe pagamenti (Fase 2)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=generate-with-openssl-rand-base64-32

# Email transazionali (Resend) — onboarding. Senza, le email sono no-op.
RESEND_API_KEY=
EMAIL_FROM=Social Automation <no-reply@tuodominio.it>
AGENCY_NOTIFY_EMAIL=

# Solo demo controllata, mai su produzione venduta
# NEXT_PUBLIC_DEMO_MODE=true
# SHOW_LOGIN_HINT=true
