# Database Supabase (Postgres) — usare il pooler Supavisor, NON la connessione diretta.
# Runtime app (Vercel serverless): pooler transaction mode, porta 6543.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
# Migrazioni + ensure-admin: pooler session mode, porta 5432 (IPv4, multi-statement/DDL).
# La connessione diretta db.<ref>.supabase.co:5432 è IPv6-only → non usarla da Vercel/CI.
DIRECT_DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI - almeno una chiave
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
# Agnes AI (apihub.agnes-ai.com) — testo + immagini + video
AGNES_API_KEY=

# Blotato (quando pronto)
BLOTATO_API_KEY=
BLOTATO_API_URL=https://backend.blotato.com
BLOTATO_BACKEND_URL=https://backend.blotato.com
BLOTATO_WEBHOOK_SECRET=generate-with-openssl-rand-base64-32

# Stripe pagamenti (Fase 2)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=generate-with-openssl-rand-base64-32

# Email transazionali (Resend) — onboarding. Senza, le email sono no-op.
RESEND_API_KEY=
EMAIL_FROM=Social Automation <no-reply@tuodominio.it>
AGENCY_NOTIFY_EMAIL=

# Cloudflare Turnstile (captcha anti-bot su /register). Senza, captcha saltato.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Storage media S3-compatible — OBBLIGATORIO su Vercel (FS read-only, niente fallback
# su disco). Consigliato Supabase Storage (Storage → S3 Access Keys per le credenziali).
STORAGE_ENDPOINT=https://<ref>.supabase.co/storage/v1/s3
STORAGE_REGION=<region>            # es. eu-central-1 — deve combaciare (firma aws4fetch)
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=media
# Opzionale: se il bucket è pubblico, URL diretto; se vuoto → proxy /api/assets/file.
# STORAGE_PUBLIC_URL=https://<ref>.supabase.co/storage/v1/object/public/media

# Solo demo controllata, mai su produzione venduta
# NEXT_PUBLIC_DEMO_MODE=true
# SHOW_LOGIN_HINT=true
